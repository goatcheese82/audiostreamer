# Audiostreamer Configuration
# Copy this to .env and fill in your values

# Server port
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgresql://audiostreamer:audiostreamer@db:5432/audiostreamer?sslmode=disable

# Path to audiobook files (must match your Unraid mount)
AUDIOBOOK_BASE_PATH=/mnt/tower/audiobooks

# FFmpeg settings
FFMPEG_PATH=ffmpeg
OPUS_BITRATE=48k
SAMPLE_RATE=48000

# Admin token for the Svelte admin UI and admin API calls
# Generate something random: openssl rand -hex 32
ADMIN_TOKEN=change-me-to-something-random

# Audiobookshelf (for metadata import, optional)
ABS_URL=http://10.0.2.8:13378
ABS_TOKEN=your-abs-api-token-here
